{
  "appId": "com.videomake2026.bridge",
  "productName": "DSC-Bridge",
  "directories": {
    "output": "../release/bridge-tray"
  },
  "files": [
    "tray/**/*",
    "server.js",
    "package.json",
    "node_modules/**/*"
  ],
  "asar": false,
  "extraResources": [
    {
      "from": "../icon.png",
      "to": "icon.png"
    }
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ],
    "artifactName": "${productName}-${version}-win-${arch}-installer.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "allowElevation": true,
    "createDesktopShortcut": true
  },
  "mac": {
    "target": [
      "zip"
    ],
    "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
    "category": "public.app-category.utilities"
  }
}
